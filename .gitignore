# Runtime data — never committed
/in/*
/out/*
/models/*
!**/.gitkeep

# Local machine config (paths, endpoints, reader api_key) — never committed.
# config.example.toml is the committed template; config.toml is per-machine.
/config.toml

# Per-project secrets (FUSION_OCR_API_TOKEN) — never committed.
/.env

# Hand-labelled eval — the live manifest + transcripts quote source material (repo is
# public), so they stay local. labelset.example.json is the committed template.
/eval_labels/labelset.json
/eval_labels/*.txt

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
build/
dist/

# OS / editor
.DS_Store
.idea/
.vscode/

# Real sample documents — confidential, NEVER commit. Develop against these
# locally; tests skip cleanly when they're absent.
/samples/*
!samples/.gitkeep
# Eval outputs are bulky and machine-local — EXCEPT the durable evidence record the evidence
# plan requires committed: manifests, the run scripts that produced the numbers, and each run's
# aggregate results.csv (all small; pure metrics/metadata, no source text). The bulky per-item
# out/ trees (overlay PDFs, per-stage JSON) stay local + archived off-repo.
/eval_out/*
!/eval_out/manifests/
!/eval_out/*.py
!/eval_out/noise_floor/
!/eval_out/ocrq_full/
!/eval_out/stream_a/
!/eval_out/stream_a_vlm/
/eval_out/noise_floor/*
/eval_out/ocrq_full/*
/eval_out/stream_a/*
/eval_out/stream_a_vlm/*
!/eval_out/noise_floor/results.csv
!/eval_out/ocrq_full/results.csv
!/eval_out/stream_a/results.csv
!/eval_out/stream_a_vlm/results.csv
