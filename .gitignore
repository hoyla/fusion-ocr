# Runtime data — never committed
/in/*
/out/*
/models/*
!**/.gitkeep

# Local machine config (paths, endpoints, reader api_key) — never committed.
# config.example.toml is the committed template; config.toml is per-machine.
/config.toml

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
build/
dist/

# OS / editor
.DS_Store
.idea/
.vscode/

# Real sample documents — confidential, NEVER commit. Develop against these
# locally; tests skip cleanly when they're absent.
/samples/*
!samples/.gitkeep
