# fusion-ocr environment — template.
#
# Copy to `.env` (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# These are SECRETS / per-machine settings and must never be committed. They are
# kept out of config.toml on purpose — config.example.toml is the non-secret template.

# --- API auth (required to serve the HTTP job API) -------------------------------
# Bearer token for the HTTP API (`fusion-ocr-serve` + the queue worker). The API is
# fail-closed: it refuses to start if this is unset, and rejects any request whose
# `Authorization: Bearer <token>` header doesn't match (constant-time compare).
# Use a long, random, unguessable value — generate one with:
#     python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Clients on the LAN send the same value in the Authorization header.
FUSION_OCR_API_TOKEN=replace-with-a-strong-random-token
